#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage: bw-lock

Locks the active Bitwarden CLI vault session and removes the runtime
BW_SESSION file. This command does not log out of Bitwarden.
EOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  "")
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

export HOME="${HOME:-/home/hermes}"
export BITWARDENCLI_APPDATA_DIR="${BITWARDENCLI_APPDATA_DIR:-$HOME/.local/state/bitwarden-cli}"
runtime_dir="${XDG_RUNTIME_DIR:-/run/user/3000}"
session_dir="$runtime_dir/ghostship-bitwarden"
session_file="$session_dir/session.env"

if [ -z "${BW_SESSION:-}" ] && [ -f "$session_file" ]; then
  # shellcheck disable=SC1090
  . "$session_file"
  export BW_SESSION="${BW_SESSION:-}"
fi

if command -v bw >/dev/null 2>&1; then
  bw lock >/dev/null 2>&1 || true
fi

rm -f "$session_file"
printf '{"ok":true,"status":"locked"}\n'
