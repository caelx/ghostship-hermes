#!/command/with-contenv bash
set -euo pipefail

export GHOSTSHIP_CAMOFOX_VNC_PORT="${GHOSTSHIP_CAMOFOX_VNC_PORT:-5901}"
export GHOSTSHIP_CAMOFOX_WEB_PORT="${GHOSTSHIP_CAMOFOX_WEB_PORT:-6080}"

# noVNC/websockify is the browser-friendly port Hermes advertises from CAMOFOX_URL/health.
exec websockify \
  --web=/usr/share/novnc \
  "127.0.0.1:${GHOSTSHIP_CAMOFOX_WEB_PORT}" \
  "127.0.0.1:${GHOSTSHIP_CAMOFOX_VNC_PORT}"
