#!/command/with-contenv bash
set -euo pipefail

export HOME="${HOME:-/home/hermes}"
export HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export GHOSTSHIP_WORKSPACE_ROOT="${GHOSTSHIP_WORKSPACE_ROOT:-/workspace}"
export GHOSTSHIP_NIX_DEFAULT_PROFILE="${GHOSTSHIP_NIX_DEFAULT_PROFILE:-/nix/var/nix/profiles/per-user/hermes/ghostship-defaults}"
internal_env_dir="/run/ghostship"
internal_env_file="$internal_env_dir/internal.env"
hermes_env_file="$internal_env_dir/hermes.env"
persisted_hermes_env_file="$HERMES_HOME/.env"
persisted_hermes_env_keys_file="$HERMES_HOME/.ghostship-managed-env.keys"

. /etc/ghostship-hermes-env.sh

mkdir -p "$HOME" "$HERMES_HOME" "$XDG_CONFIG_HOME" "$XDG_CACHE_HOME" "$XDG_DATA_HOME" "$HOME/.local/bin" "$HOME/.local/state" "$HOME/.local/state/tmux" "$HOME/.local/state/ghostship-hermes/ttyd" "$HOME/.npm" "$HOME/.cargo" "$HOME/.rustup" "$HOME/.ssh" "$GHOSTSHIP_WORKSPACE_ROOT" /run/user/3000 "$internal_env_dir"
chown -R 3000:3000 "$HOME" "$GHOSTSHIP_WORKSPACE_ROOT" /run/user/3000 "$internal_env_dir"
chmod 0700 /run/user/3000

# Pre-create the supported persisted browser profile root as hermes.
mkdir -p "$HOME/.local/state/cloakbrowser"
chown -R 3000:3000 "$HOME/.local/state/cloakbrowser"

touch "$internal_env_file"
chown 3000:3000 "$internal_env_file"
chmod 0600 "$internal_env_file"

if [ ! -d /nix/store ] || [ -z "$(find /nix/store -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]; then
  mkdir -p /nix
  tar --zstd -xf /opt/ghostship/nix-seed.tar.zst -C /
fi

mkdir -p /nix/var/nix/profiles/per-user/hermes /nix/var/nix/gcroots/per-user/hermes
chown -R 3000:3000 /nix/var/nix/profiles/per-user/hermes /nix/var/nix/gcroots/per-user/hermes

default_tools_out_path_file="/opt/ghostship/nix-default-tools.out-path"
default_tools_export_file="/opt/ghostship/nix-default-tools.export.zst"
if [ -f "$default_tools_out_path_file" ]; then
  default_tools_out_path="$(cat "$default_tools_out_path_file")"
  if [ ! -e "$default_tools_out_path" ]; then
    zstd -dc "$default_tools_export_file" | runuser -u hermes -- env HOME="$HOME" PATH="$HOME/.nix-profile/bin:/usr/local/bin:/usr/bin:/bin" nix-store --import >/dev/null
  fi
  if [ ! -e "$default_tools_out_path" ]; then
    echo "managed Nix default profile path missing after import: $default_tools_out_path" >&2
    exit 1
  fi
  ln -sfn "$default_tools_out_path" "$GHOSTSHIP_NIX_DEFAULT_PROFILE"
  chown -h 3000:3000 "$GHOSTSHIP_NIX_DEFAULT_PROFILE"
  ln -sfn "$default_tools_out_path" /nix/var/nix/gcroots/per-user/hermes/ghostship-defaults
  chown -h 3000:3000 /nix/var/nix/gcroots/per-user/hermes/ghostship-defaults
fi

if [ -d /opt/ghostship/home-seed ]; then
  tar -C /opt/ghostship/home-seed -cf - . | tar -C "$HOME" --skip-old-files -xf -
fi

declare -A hermes_env_values=()
ghostship_collect_hermes_env hermes_env_values "${GHOSTSHIP_TERMINAL_CWD:-/workspace}"
ghostship_write_hermes_env_file "$hermes_env_file" hermes_env_values
ghostship_merge_hermes_env_file "$persisted_hermes_env_file" "$hermes_env_file" "$persisted_hermes_env_keys_file"
ghostship_write_hermes_env_keys_file "$persisted_hermes_env_keys_file" hermes_env_values

chown -R 3000:3000 "$HOME" "$GHOSTSHIP_WORKSPACE_ROOT"
chown 3000:3000 "$hermes_env_file"
chmod 0600 "$hermes_env_file"

ln -sfn /nix/var/nix/profiles/per-user/hermes/profile "$HOME/.nix-profile"
chown -h 3000:3000 "$HOME/.nix-profile"

HOME="$HOME" HERMES_HOME="$HERMES_HOME" GHOSTSHIP_WORKSPACE_ROOT="$GHOSTSHIP_WORKSPACE_ROOT" /command/s6-setuidgid hermes /opt/hermes/venv/bin/python /opt/ghostship/bin/init_home.py
HOME="$HOME" HERMES_HOME="$HERMES_HOME" PATH="/opt/ghostship/bin:/opt/hermes/venv/bin:$HOME/.local/bin:$HOME/.nix-profile/bin:$GHOSTSHIP_NIX_DEFAULT_PROFILE/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" /command/s6-setuidgid hermes /opt/hermes/venv/bin/hermes skills list >/dev/null 2>&1 || true
