#!/command/with-contenv bash
set -euo pipefail

export HOME="${HOME:-/home/hermes}"
export HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export GHOSTSHIP_WORKSPACE_ROOT="${GHOSTSHIP_WORKSPACE_ROOT:-/workspace}"
internal_env_dir="/run/ghostship"
internal_env_file="$internal_env_dir/internal.env"

mkdir -p "$HOME" "$HERMES_HOME" "$XDG_CONFIG_HOME" "$XDG_CACHE_HOME" "$XDG_DATA_HOME" "$HOME/.local/bin" "$HOME/.local/state" "$HOME/.local/state/tmux" "$HOME/.local/state/ghostship-hermes/ttyd" "$HOME/.npm" "$HOME/.cargo" "$HOME/.rustup" "$HOME/.ssh" "$GHOSTSHIP_WORKSPACE_ROOT" /run/user/3000 "$internal_env_dir"
chown -R 3000:3000 "$HOME" "$GHOSTSHIP_WORKSPACE_ROOT" /run/user/3000 "$internal_env_dir"
chmod 0700 /run/user/3000

router_api_key="$(python3 - <<'PY'
import secrets
print(secrets.token_urlsafe(32))
PY
)"
printf '_GHOSTSHIP_ROUTER_API_KEY=%s\n' "$router_api_key" > "$internal_env_file"
chown 3000:3000 "$internal_env_file"
chmod 0600 "$internal_env_file"

if [ ! -d /nix/store ] || [ -z "$(find /nix/store -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]; then
  mkdir -p /nix
  tar --zstd -xf /opt/ghostship/nix-seed.tar.zst -C /
fi

mkdir -p /nix/var/nix/profiles/per-user/hermes /nix/var/nix/gcroots/per-user/hermes
chown -R 3000:3000 /nix/var/nix/profiles/per-user/hermes /nix/var/nix/gcroots/per-user/hermes

if [ -d /opt/ghostship/home-seed ]; then
  tar -C /opt/ghostship/home-seed -cf - . | tar -C "$HOME" --skip-old-files -xf -
fi

ln -sfn /nix/var/nix/profiles/per-user/hermes/profile "$HOME/.nix-profile"
chown -h 3000:3000 "$HOME/.nix-profile"

HOME="$HOME" HERMES_HOME="$HERMES_HOME" GHOSTSHIP_WORKSPACE_ROOT="$GHOSTSHIP_WORKSPACE_ROOT" /command/s6-setuidgid hermes /opt/hermes/venv/bin/python /opt/ghostship/bin/init_home.py
HOME="$HOME" HERMES_HOME="$HERMES_HOME" PATH="/opt/ghostship-utils/venv/bin:/opt/ghostship/bin:/opt/hermes/venv/bin:/opt/ghostship-router/venv/bin:$HOME/.local/bin:$HOME/.nix-profile/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" /command/s6-setuidgid hermes /opt/hermes/venv/bin/hermes skills list >/dev/null 2>&1 || true
