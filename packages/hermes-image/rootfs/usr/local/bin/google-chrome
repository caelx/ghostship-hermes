#!/usr/bin/env bash
set -euo pipefail

binary="/opt/ghostship/cloakbrowser-current/chrome"
profile_root="/home/hermes/.local/state/cloakbrowser"
python_bin="/opt/cloakbrowser-venv/bin/python"

if [ ! -x "$binary" ]; then
  echo "cloakbrowser binary missing at $binary" >&2
  exit 1
fi

if [ ! -x "$python_bin" ]; then
  echo "cloakbrowser helper python missing at $python_bin" >&2
  exit 1
fi

mkdir -p "$profile_root"
chmod 0750 "$profile_root" 2>/dev/null || true

mapfile -d '' -t stealth_args < <("$python_bin" - <<'PY'
from cloakbrowser.config import get_default_stealth_args
import sys

for arg in get_default_stealth_args():
    sys.stdout.write(arg)
    sys.stdout.write("\0")
PY
)

args=()
has_user_data_dir=false
has_log_level=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --user-data-dir=*)
      has_user_data_dir=true
      args+=("$1")
      shift
      ;;
    --user-data-dir)
      has_user_data_dir=true
      if [ "$#" -lt 2 ]; then
        echo "--user-data-dir requires a value" >&2
        exit 2
      fi
      args+=("$1" "$2")
      shift 2
      ;;
    --log-level=*)
      has_log_level=true
      args+=("$1")
      shift
      ;;
    --log-level)
      has_log_level=true
      if [ "$#" -lt 2 ]; then
        echo "--log-level requires a value" >&2
        exit 2
      fi
      args+=("$1" "$2")
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [ "$has_user_data_dir" = false ]; then
  args+=("--user-data-dir=${profile_root}")
fi

if [ "$has_log_level" = false ]; then
  args+=("--log-level=3")
fi

exec "$binary" "${stealth_args[@]}" "${args[@]}"
